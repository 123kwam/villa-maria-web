# Resend — sends contact-form submissions to the restaurant inbox.
# Required for /api/contact to work. Without RESEND_API_KEY the form
# returns 500 and the visitor sees the generic error message.
#
# Setup: create a free account at resend.com → API Keys → create key →
# paste below for local dev, and add the same to Vercel project env vars
# (Production + Preview).
RESEND_API_KEY=

# Sender. Until restaurantvillamaria.nl is verified in Resend (Resend
# dashboard → Domains), keep the default onboarding sender below.
# Once the domain is verified, swap to something like:
#   Villa Maria <noreply@restaurantvillamaria.nl>
RESEND_FROM="Villa Maria Website <onboarding@resend.dev>"

# Inbox that receives form submissions. The visitor's email is set as
# Reply-To so the owner can just hit reply.
RESEND_TO=info@restaurantvillamaria.nl
